@'
# Virtual Environment
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Environment variables
.env
.last_pdf_name
.database_cleared

# IDE
.vscode/
.idea/
*.swp
*.swo

# Streamlit cache
.streamlit/
.cache/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# gitsteps
.gitsteps

# Local run scripts
run.bat
run.sh

# Temporary files
*.tmp
*.temp
'@ | Out-File -FilePath .gitignore -Encoding UTF8